{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "sources",
  "description": "Repository sources for OpenSpec working space",
  "type": "object",
  "required": ["repos"],
  "additionalProperties": false,
  "properties": {
    "repos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["alias", "url"],
        "additionalProperties": false,
        "properties": {
          "alias": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Local alias used as the clone directory name under sources/"
          },
          "url": {
            "type": "string",
            "minLength": 1,
            "description": "git clone URL (ssh or https)"
          },
          "branch": {
            "type": "string",
            "minLength": 1,
            "description": "Optional branch to clone instead of the default branch"
          }
        }
      }
    }
  }
}
